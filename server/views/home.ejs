<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Create short, memorable links and track every click.">
    <title>Linkly — Smarter short links</title>
    <style>
        :root {
            --navy: #101828;
            --navy-soft: #1d2939;
            --ink: #344054;
            --muted: #667085;
            --line: #e4e7ec;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --brand: #6941c6;
            --brand-dark: #53389e;
            --brand-soft: #f4f3ff;
            --cyan: #12b7c4;
            --success: #067647;
            --success-soft: #ecfdf3;
            --danger: #b42318;
            --danger-soft: #fef3f2;
            --shadow-sm: 0 1px 3px rgba(16, 24, 40, 0.08);
            --shadow-lg: 0 24px 64px rgba(16, 24, 40, 0.14);
            --radius: 18px;
        }

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            color: var(--navy);
            background: var(--surface);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        button,
        input {
            font: inherit;
        }

        a {
            color: inherit;
        }

        .container {
            width: min(1180px, calc(100% - 40px));
            margin: 0 auto;
        }

        .navbar {
            position: sticky;
            top: 0;
            z-index: 50;
            border-bottom: 1px solid rgba(228, 231, 236, 0.8);
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(18px);
        }

        .nav-inner {
            min-height: 74px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 28px;
        }

        .brand {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 850;
            letter-spacing: -0.04em;
            text-decoration: none;
        }

        .brand-mark {
            width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            color: #ffffff;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
            box-shadow: 0 10px 24px rgba(105, 65, 198, 0.26);
        }

        .brand-mark svg {
            width: 21px;
            height: 21px;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .nav-links a {
            color: var(--ink);
            font-size: 14px;
            font-weight: 650;
            text-decoration: none;
            transition: color 160ms ease;
        }

        .nav-links a:hover {
            color: var(--brand);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-chip {
            max-width: 190px;
            overflow: hidden;
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .button {
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: 1px solid transparent;
            border-radius: 10px;
            padding: 0 17px;
            font-weight: 750;
            text-decoration: none;
            cursor: pointer;
            transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
        }

        .button:hover {
            transform: translateY(-1px);
        }

        .button-primary {
            color: #ffffff;
            background: var(--brand);
            box-shadow: 0 8px 18px rgba(105, 65, 198, 0.22);
        }

        .button-primary:hover {
            background: var(--brand-dark);
            box-shadow: 0 12px 24px rgba(105, 65, 198, 0.28);
        }

        .button-ghost {
            border-color: var(--line);
            color: var(--ink);
            background: #ffffff;
        }

        .hero {
            position: relative;
            overflow: hidden;
            padding: 86px 0 76px;
            background:
                radial-gradient(circle at 8% 22%, rgba(18, 183, 196, 0.14), transparent 26%),
                radial-gradient(circle at 92% 18%, rgba(105, 65, 198, 0.16), transparent 28%),
                linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
        }

        .hero::after {
            content: "";
            position: absolute;
            inset: auto 0 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--line), transparent);
        }

        .hero-grid {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(410px, 0.82fr);
            gap: 70px;
            align-items: center;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 22px;
            border: 1px solid #d9d6fe;
            border-radius: 999px;
            padding: 7px 12px;
            color: var(--brand-dark);
            background: var(--brand-soft);
            font-size: 13px;
            font-weight: 750;
        }

        .eyebrow-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--cyan);
            box-shadow: 0 0 0 4px rgba(18, 183, 196, 0.12);
        }

        h1 {
            max-width: 700px;
            margin: 0;
            font-size: clamp(46px, 6vw, 74px);
            line-height: 0.99;
            letter-spacing: -0.065em;
        }

        .gradient-text {
            color: transparent;
            background: linear-gradient(100deg, var(--brand), var(--cyan));
            background-clip: text;
            -webkit-background-clip: text;
        }

        .hero-copy {
            max-width: 620px;
            margin: 25px 0 0;
            color: var(--muted);
            font-size: 18px;
            line-height: 1.7;
        }

        .hero-points {
            display: flex;
            flex-wrap: wrap;
            gap: 16px 24px;
            margin-top: 30px;
            color: var(--ink);
            font-size: 14px;
            font-weight: 650;
        }

        .hero-point {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .check {
            width: 20px;
            height: 20px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            color: var(--success);
            background: var(--success-soft);
            font-size: 12px;
            font-weight: 900;
        }

        .shortener-card {
            position: relative;
            border: 1px solid rgba(228, 231, 236, 0.9);
            border-radius: 24px;
            padding: 28px;
            background: rgba(255, 255, 255, 0.94);
            box-shadow: var(--shadow-lg);
        }

        .shortener-card::before {
            content: "";
            position: absolute;
            z-index: -1;
            inset: 24px -18px -18px 24px;
            border-radius: 24px;
            background: linear-gradient(135deg, rgba(105, 65, 198, 0.16), rgba(18, 183, 196, 0.12));
            filter: blur(1px);
        }

        .card-label {
            margin: 0 0 6px;
            color: var(--brand);
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .shortener-card h2 {
            margin: 0;
            font-size: 25px;
            letter-spacing: -0.035em;
        }

        .card-copy {
            margin: 9px 0 22px;
            color: var(--muted);
            font-size: 14px;
            line-height: 1.6;
        }

        .shortener-form {
            display: grid;
            gap: 12px;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            top: 50%;
            left: 16px;
            width: 20px;
            height: 20px;
            color: #98a2b3;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .url-input {
            width: 100%;
            min-height: 54px;
            border: 1px solid #d0d5dd;
            border-radius: 12px;
            padding: 0 15px 0 47px;
            color: var(--navy);
            background: #ffffff;
            outline: none;
            transition: border 160ms ease, box-shadow 160ms ease;
        }

        .url-input:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 4px rgba(105, 65, 198, 0.11);
        }

        .generate-button {
            min-height: 54px;
            border: 0;
            border-radius: 12px;
            color: #ffffff;
            background: linear-gradient(100deg, var(--brand), #7f56d9);
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 12px 24px rgba(105, 65, 198, 0.25);
            transition: transform 160ms ease, box-shadow 160ms ease;
        }

        .generate-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(105, 65, 198, 0.32);
        }

        .form-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            margin: 2px 0 0;
            color: var(--muted);
            font-size: 12px;
        }

        .alert {
            border-radius: 11px;
            padding: 12px 14px;
            font-size: 13px;
            font-weight: 650;
        }

        .alert-error {
            border: 1px solid #fecdca;
            color: var(--danger);
            background: var(--danger-soft);
        }

        .result-card {
            margin-top: 16px;
            border: 1px solid #abefc6;
            border-radius: 13px;
            padding: 14px;
            background: var(--success-soft);
        }

        .result-label {
            display: block;
            margin-bottom: 7px;
            color: var(--success);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .result-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .result-link {
            min-width: 0;
            overflow: hidden;
            color: #05603a;
            font-size: 14px;
            font-weight: 750;
            text-overflow: ellipsis;
            text-decoration: none;
            white-space: nowrap;
        }

        .copy-button {
            flex: 0 0 auto;
            min-height: 34px;
            border: 1px solid #75e0a7;
            border-radius: 8px;
            padding: 0 11px;
            color: var(--success);
            background: #ffffff;
            font-size: 12px;
            font-weight: 750;
            cursor: pointer;
        }

        .stats-strip {
            position: relative;
            z-index: 3;
            margin-top: -1px;
            border-bottom: 1px solid var(--line);
            background: #ffffff;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
        }

        .stat {
            padding: 30px;
            text-align: center;
        }

        .stat + .stat {
            border-left: 1px solid var(--line);
        }

        .stat strong {
            display: block;
            margin-bottom: 5px;
            color: var(--navy);
            font-size: 29px;
            letter-spacing: -0.04em;
        }

        .stat span {
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
        }

        .section {
            padding: 94px 0;
        }

        .section-soft {
            background: var(--surface-soft);
        }

        .section-heading {
            max-width: 680px;
            margin: 0 auto 48px;
            text-align: center;
        }

        .section-kicker {
            display: block;
            margin-bottom: 11px;
            color: var(--brand);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .section-heading h2 {
            margin: 0;
            font-size: clamp(34px, 4vw, 48px);
            line-height: 1.08;
            letter-spacing: -0.05em;
        }

        .section-heading p {
            margin: 17px auto 0;
            color: var(--muted);
            font-size: 17px;
            line-height: 1.65;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .feature-card {
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: 28px;
            background: #ffffff;
            box-shadow: var(--shadow-sm);
            transition: transform 180ms ease, box-shadow 180ms ease;
        }

        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 38px rgba(16, 24, 40, 0.09);
        }

        .feature-icon {
            width: 48px;
            height: 48px;
            display: grid;
            place-items: center;
            margin-bottom: 22px;
            border-radius: 13px;
            color: var(--brand);
            background: var(--brand-soft);
        }

        .feature-icon svg {
            width: 23px;
            height: 23px;
        }

        .feature-card h3 {
            margin: 0 0 9px;
            font-size: 19px;
            letter-spacing: -0.025em;
        }

        .feature-card p {
            margin: 0;
            color: var(--muted);
            font-size: 14px;
            line-height: 1.7;
        }

        .dashboard-card {
            border: 1px solid var(--line);
            border-radius: 22px;
            background: #ffffff;
            box-shadow: 0 16px 48px rgba(16, 24, 40, 0.08);
            overflow: hidden;
        }

        .dashboard-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 24px;
            padding: 28px 30px;
            border-bottom: 1px solid var(--line);
        }

        .dashboard-head h2 {
            margin: 0 0 7px;
            font-size: 25px;
            letter-spacing: -0.035em;
        }

        .dashboard-head p {
            margin: 0;
            color: var(--muted);
            font-size: 14px;
        }

        .count-badge {
            min-height: 32px;
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 0 12px;
            color: var(--brand-dark);
            background: var(--brand-soft);
            font-size: 12px;
            font-weight: 800;
            white-space: nowrap;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 780px;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 16px 22px;
            border-bottom: 1px solid var(--line);
            text-align: left;
            vertical-align: middle;
        }

        th {
            color: var(--muted);
            background: #fcfcfd;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        tbody tr:last-child td {
            border-bottom: 0;
        }

        tbody tr:hover {
            background: #fcfcfd;
        }

        td {
            color: var(--ink);
            font-size: 13px;
        }

        .short-link {
            color: var(--brand);
            font-weight: 750;
            text-decoration: none;
        }

        .short-link:hover {
            text-decoration: underline;
        }

        .destination {
            max-width: 330px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .click-badge {
            min-width: 34px;
            display: inline-flex;
            justify-content: center;
            border-radius: 999px;
            padding: 5px 9px;
            color: #026aa2;
            background: #f0f9ff;
            font-weight: 750;
        }

        .delete-button {
            min-height: 34px;
            border: 1px solid #fecdca;
            border-radius: 8px;
            padding: 0 11px;
            color: var(--danger);
            background: #ffffff;
            font-size: 12px;
            font-weight: 750;
            cursor: pointer;
        }

        .delete-button:hover {
            background: var(--danger-soft);
        }

        .empty-state {
            padding: 58px 24px;
            text-align: center;
        }

        .empty-icon {
            width: 52px;
            height: 52px;
            display: grid;
            place-items: center;
            margin: 0 auto 16px;
            border-radius: 14px;
            color: var(--brand);
            background: var(--brand-soft);
        }

        .empty-state h3 {
            margin: 0 0 7px;
            font-size: 17px;
        }

        .empty-state p {
            margin: 0;
            color: var(--muted);
            font-size: 14px;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            align-items: stretch;
        }

        .price-card {
            position: relative;
            display: flex;
            flex-direction: column;
            border: 1px solid var(--line);
            border-radius: 20px;
            padding: 30px;
            background: #ffffff;
            box-shadow: var(--shadow-sm);
        }

        .price-card.popular {
            border: 2px solid var(--brand);
            box-shadow: 0 22px 48px rgba(105, 65, 198, 0.16);
            transform: translateY(-8px);
        }

        .popular-badge {
            position: absolute;
            top: -14px;
            left: 50%;
            border-radius: 999px;
            padding: 7px 13px;
            color: #ffffff;
            background: var(--brand);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            transform: translateX(-50%);
        }

        .price-card h3 {
            margin: 0;
            font-size: 19px;
        }

        .price-description {
            min-height: 44px;
            margin: 8px 0 22px;
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
        }

        .price {
            margin-bottom: 24px;
            color: var(--navy);
            font-size: 42px;
            font-weight: 850;
            letter-spacing: -0.055em;
        }

        .price small {
            color: var(--muted);
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0;
        }

        .price-features {
            display: grid;
            gap: 13px;
            margin: 0 0 28px;
            padding: 0;
            list-style: none;
        }

        .price-features li {
            display: flex;
            align-items: center;
            gap: 9px;
            color: var(--ink);
            font-size: 13px;
        }

        .price-card .button {
            width: 100%;
            margin-top: auto;
        }

        .cta {
            padding: 0 0 94px;
            background: var(--surface-soft);
        }

        .cta-card {
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 40px;
            border-radius: 24px;
            padding: 48px 54px;
            color: #ffffff;
            background: linear-gradient(120deg, #42307d, var(--brand), #0e9384);
            box-shadow: 0 24px 56px rgba(66, 48, 125, 0.24);
        }

        .cta-card::after {
            content: "";
            position: absolute;
            top: -110px;
            right: -80px;
            width: 300px;
            height: 300px;
            border: 1px solid rgba(255, 255, 255, 0.17);
            border-radius: 50%;
            box-shadow: 0 0 0 45px rgba(255, 255, 255, 0.05), 0 0 0 90px rgba(255, 255, 255, 0.035);
        }

        .cta-copy {
            position: relative;
            z-index: 1;
        }

        .cta-card h2 {
            margin: 0 0 10px;
            font-size: 34px;
            letter-spacing: -0.045em;
        }

        .cta-card p {
            margin: 0;
            color: rgba(255, 255, 255, 0.76);
            line-height: 1.6;
        }

        .cta-card .button {
            position: relative;
            z-index: 1;
            flex: 0 0 auto;
            color: var(--brand-dark);
            background: #ffffff;
        }

        .footer {
            color: #d0d5dd;
            background: var(--navy);
        }

        .footer-main {
            display: grid;
            grid-template-columns: 1.5fr repeat(3, 0.7fr);
            gap: 50px;
            padding: 62px 0 48px;
        }

        .footer .brand {
            color: #ffffff;
        }

        .footer-about {
            max-width: 330px;
            margin: 18px 0 0;
            color: #98a2b3;
            font-size: 14px;
            line-height: 1.7;
        }

        .footer-column h3 {
            margin: 0 0 18px;
            color: #ffffff;
            font-size: 13px;
            letter-spacing: 0.03em;
        }

        .footer-links {
            display: grid;
            gap: 13px;
        }

        .footer-links a {
            color: #98a2b3;
            font-size: 13px;
            text-decoration: none;
        }

        .footer-links a:hover {
            color: #ffffff;
        }

        .footer-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            border-top: 1px solid #344054;
            padding: 24px 0;
            color: #98a2b3;
            font-size: 12px;
        }

        .menu-button {
            display: none;
            width: 42px;
            height: 42px;
            border: 1px solid var(--line);
            border-radius: 10px;
            color: var(--navy);
            background: #ffffff;
            cursor: pointer;
        }

        @media (max-width: 960px) {
            .hero-grid {
                grid-template-columns: 1fr;
                gap: 52px;
            }

            .hero-copy {
                max-width: 720px;
            }

            .shortener-card {
                max-width: 650px;
            }

            .features-grid,
            .pricing-grid {
                grid-template-columns: 1fr 1fr;
            }

            .features-grid .feature-card:last-child,
            .pricing-grid .price-card:last-child {
                grid-column: 1 / -1;
            }

            .price-card.popular {
                transform: none;
            }

            .footer-main {
                grid-template-columns: 1.3fr 1fr 1fr;
            }

            .footer-main > :last-child {
                display: none;
            }
        }

        @media (max-width: 760px) {
            .container {
                width: min(100% - 28px, 1180px);
            }

            .nav-inner {
                min-height: 68px;
                flex-wrap: wrap;
            }

            .menu-button {
                display: grid;
                place-items: center;
            }

            .nav-links {
                order: 4;
                width: 100%;
                display: none;
                align-items: stretch;
                gap: 0;
                padding: 0 0 16px;
            }

            .nav-links.open {
                display: grid;
            }

            .nav-links a {
                padding: 11px 0;
            }

            .user-chip {
                display: none;
            }

            .hero {
                padding: 62px 0;
            }

            h1 {
                font-size: clamp(43px, 14vw, 64px);
            }

            .hero-copy {
                font-size: 16px;
            }

            .shortener-card {
                padding: 22px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .stat + .stat {
                border-top: 1px solid var(--line);
                border-left: 0;
            }

            .section {
                padding: 72px 0;
            }

            .features-grid,
            .pricing-grid {
                grid-template-columns: 1fr;
            }

            .features-grid .feature-card:last-child,
            .pricing-grid .price-card:last-child {
                grid-column: auto;
            }

            .dashboard-head,
            .cta-card {
                align-items: flex-start;
                flex-direction: column;
            }

            .cta-card {
                padding: 36px 28px;
            }

            .footer-main {
                grid-template-columns: 1fr 1fr;
            }

            .footer-brand {
                grid-column: 1 / -1;
            }
        }

        @media (max-width: 480px) {
            .nav-actions .button {
                min-height: 39px;
                padding: 0 12px;
                font-size: 12px;
            }

            .brand {
                font-size: 18px;
            }

            .brand-mark {
                width: 35px;
                height: 35px;
            }

            .hero-points {
                display: grid;
            }

            .result-row {
                align-items: stretch;
                flex-direction: column;
            }

            .copy-button {
                align-self: flex-start;
            }

            .footer-main {
                grid-template-columns: 1fr;
            }

            .footer-brand {
                grid-column: auto;
            }

            .footer-bottom {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <%
        const linkCount = locals.urls ? urls.length : 0;
        const totalClicks = locals.urls
            ? urls.reduce((total, url) => total + url.VisitHistory.length, 0)
            : 0;
        const shortUrl = locals.id ? `${locals.baseUrl || ""}/url/${id}` : "";
    %>

    <nav class="navbar" aria-label="Main navigation">
        <div class="container nav-inner">
            <a class="brand" href="/">
                <span class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                    </svg>
                </span>
                <span>Linkly</span>
            </a>

            <button class="menu-button" type="button" aria-label="Toggle navigation" aria-expanded="false" onclick="toggleMenu(this)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 7h16M4 12h16M4 17h16"/>
                </svg>
            </button>

            <div class="nav-links" id="navLinks">
                <a href="#features">Features</a>
                <a href="<%= user ? "#dashboard" : "/login" %>"><%= user ? "My links" : "Dashboard" %></a>
                <a href="#pricing">Pricing</a>
                <a href="#about">About</a>
            </div>

            <div class="nav-actions">
                <% if (user) { %>
                    <span class="user-chip" title="<%= user.email %>"><%= user.email %></span>
                    <form action="/user/logout" method="POST">
                        <button type="submit" class="button button-ghost">Log out</button>
                    </form>
                <% } else { %>
                    <a class="button button-ghost" href="/login">Log in</a>
                    <a class="button button-primary" href="/signup">Sign up</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main>
        <section class="hero">
            <div class="container hero-grid">
                <div>
                    <div class="eyebrow">
                        <span class="eyebrow-dot"></span>
                        Simple links. Powerful results.
                    </div>
                    <h1>Make every link <span class="gradient-text">work harder.</span></h1>
                    <p class="hero-copy">
                        Turn long, messy URLs into clean links your audience will trust. Share them anywhere and see every click from one beautifully simple dashboard.
                    </p>
                    <div class="hero-points">
                        <span class="hero-point"><span class="check">✓</span>No setup required</span>
                        <span class="hero-point"><span class="check">✓</span>Real-time click tracking</span>
                        <span class="hero-point"><span class="check">✓</span>Share anywhere</span>
                    </div>
                </div>

                <aside class="shortener-card" id="shorten" aria-labelledby="shortener-title">
                    <p class="card-label">Create your link</p>
                    <h2 id="shortener-title">Shorten a URL</h2>
                    <p class="card-copy">Paste your destination below. We will turn it into an eight-character short link.</p>

                    <% if (user) { %>
                        <form class="shortener-form" method="POST" action="/url">
                            <% if (locals.error) { %>
                                <div class="alert alert-error"><%= error %></div>
                            <% } %>

                            <div class="input-wrap">
                                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                </svg>
                                <input class="url-input" type="url" name="url" id="url" placeholder="https://your-long-url.com" aria-label="Destination URL" required>
                            </div>
                            <button class="generate-button" type="submit">Shorten my link →</button>
                            <p class="form-note">
                                <span aria-hidden="true">🔒</span>
                                Your links are private to your account
                            </p>
                        </form>
                    <% } else { %>
                        <form class="shortener-form" method="POST" action="/url">
                            <div class="input-wrap">
                                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                                </svg>
                                <input class="url-input" type="url" name="url" placeholder="https://your-long-url.com" aria-label="Destination URL" required>
                            </div>
                            <button class="generate-button" type="submit">Generate link →</button>
                        </form>
                    <% } %>

                    <% if (locals.id) { %>
                        <div class="result-card" aria-live="polite">
                            <span class="result-label">Your link is ready</span>
                            <div class="result-row">
                                <a class="result-link" href="/url/<%= id %>" target="_blank" rel="noopener noreferrer"><%= shortUrl %></a>
                                <button class="copy-button" type="button" data-copy="<%= shortUrl %>" onclick="copyLink(this)">Copy</button>
                            </div>
                        </div>
                    <% } %>
                </aside>
            </div>
        </section>

        <section class="stats-strip" aria-label="Account summary">
            <div class="container stats-grid">
                <div class="stat">
                    <strong><%= linkCount %></strong>
                    <span>Short links created</span>
                </div>
                <div class="stat">
                    <strong><%= totalClicks %></strong>
                    <span>Total link visits</span>
                </div>
                <div class="stat">
                    <strong>8 chars</strong>
                    <span>Clean, memorable IDs</span>
                </div>
            </div>
        </section>

        <section class="section section-soft" id="features">
            <div class="container">
                <div class="section-heading">
                    <span class="section-kicker">Everything you need</span>
                    <h2>More than a shorter URL</h2>
                    <p>Linkly gives you a focused set of tools to share confidently, understand engagement, and keep every destination organized.</p>
                </div>

                <div class="features-grid">
                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                            </svg>
                        </div>
                        <h3>Instant short links</h3>
                        <p>Create compact, shareable URLs in a single click. No confusing settings or unnecessary steps.</p>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 3v18h18"/>
                                <path d="m7 16 4-5 4 3 5-7"/>
                            </svg>
                        </div>
                        <h3>Click analytics</h3>
                        <p>See how often each link is visited and quickly understand which destinations attract attention.</p>
                    </article>

                    <article class="feature-card">
                        <div class="feature-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
                                <path d="m9 12 2 2 4-4"/>
                            </svg>
                        </div>
                        <h3>Secure by default</h3>
                        <p>Your dashboard belongs to you. Account-based ownership keeps link management safely separated.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="section" id="dashboard">
            <div class="container">
                <div class="dashboard-card">
                    <div class="dashboard-head">
                        <div>
                            <h2><%= user ? "Your link dashboard" : "Your dashboard starts here" %></h2>
                            <p><%= user ? "Review destinations, open short links, and monitor visits." : "Log in to manage short links and see click activity in one place." %></p>
                        </div>
                        <span class="count-badge"><%= linkCount %> <%= linkCount === 1 ? "link" : "links" %></span>
                    </div>

                    <% if (!user) { %>
                        <div class="empty-state">
                            <div class="empty-icon" aria-hidden="true">↗</div>
                            <h3>Sign in to unlock your dashboard</h3>
                            <p><a class="short-link" href="/login">Log in</a> or <a class="short-link" href="/signup">create a free account</a> to start shortening URLs.</p>
                        </div>
                    <% } else if (locals.urls && urls.length) { %>
                        <div class="table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Short link</th>
                                        <th>Destination</th>
                                        <th>Clicks</th>
                                        <th>Created</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% urls.forEach((url) => { %>
                                        <tr>
                                            <td>
                                                <a class="short-link" href="/url/<%= url.Shortid %>" target="_blank" rel="noopener noreferrer">
                                                    /url/<%= url.Shortid %>
                                                </a>
                                            </td>
                                            <td class="destination" title="<%= url.RedirectUrl %>"><%= url.RedirectUrl %></td>
                                            <td><span class="click-badge"><%= url.VisitHistory.length %></span></td>
                                            <td><%= new Date(url.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></td>
                                            <td>
                                                <button class="delete-button" type="button" onclick="deleteURL('<%= url.Shortid %>', this)">Delete</button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-icon" aria-hidden="true">↗</div>
                            <h3>No links yet</h3>
                            <p>Your first short link will appear here after you create it above.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="section section-soft" id="pricing">
            <div class="container">
                <div class="section-heading">
                    <span class="section-kicker">Simple pricing</span>
                    <h2>Start free. Grow when you are ready.</h2>
                    <p>No complicated calculators or surprise fees. Pick the plan that matches the way you share.</p>
                </div>

                <div class="pricing-grid">
                    <article class="price-card">
                        <h3>Starter</h3>
                        <p class="price-description">For personal projects and occasional sharing.</p>
                        <div class="price">$0 <small>/ forever</small></div>
                        <ul class="price-features">
                            <li><span class="check">✓</span>Unlimited short links</li>
                            <li><span class="check">✓</span>Basic click tracking</li>
                            <li><span class="check">✓</span>Personal dashboard</li>
                        </ul>
                        <a class="button button-ghost" href="<%= user ? "#shorten" : "/signup" %>"><%= user ? "Current plan" : "Start free" %></a>
                    </article>

                    <article class="price-card popular">
                        <span class="popular-badge">Most popular</span>
                        <h3>Creator</h3>
                        <p class="price-description">For creators who share links every day.</p>
                        <div class="price">$9 <small>/ month</small></div>
                        <ul class="price-features">
                            <li><span class="check">✓</span>Everything in Starter</li>
                            <li><span class="check">✓</span>Advanced analytics</li>
                            <li><span class="check">✓</span>Custom short aliases</li>
                            <li><span class="check">✓</span>QR code downloads</li>
                        </ul>
                        <a class="button button-primary" href="#shorten">Start creating</a>
                    </article>

                    <article class="price-card">
                        <h3>Business</h3>
                        <p class="price-description">For teams managing campaigns at scale.</p>
                        <div class="price">$29 <small>/ month</small></div>
                        <ul class="price-features">
                            <li><span class="check">✓</span>Everything in Creator</li>
                            <li><span class="check">✓</span>Team workspaces</li>
                            <li><span class="check">✓</span>Branded domains</li>
                            <li><span class="check">✓</span>Priority support</li>
                        </ul>
                        <a class="button button-ghost" href="#about">Contact us</a>
                    </article>
                </div>
            </div>
        </section>

        <section class="cta">
            <div class="container">
                <div class="cta-card">
                    <div class="cta-copy">
                        <h2>Ready to make your next link count?</h2>
                        <p>Create a cleaner URL in seconds and start tracking its reach.</p>
                    </div>
                    <a class="button" href="#shorten">Shorten a link →</a>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer" id="about">
        <div class="container footer-main">
            <div class="footer-brand">
                <a class="brand" href="/">
                    <span class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                        </svg>
                    </span>
                    <span>Linkly</span>
                </a>
                <p class="footer-about">Clean links, useful insights, and a simple dashboard—everything you need to make every share more effective.</p>
            </div>

            <div class="footer-column">
                <h3>Product</h3>
                <div class="footer-links">
                    <a href="#features">Features</a>
                    <a href="#pricing">Pricing</a>
                    <a href="#dashboard">Dashboard</a>
                </div>
            </div>

            <div class="footer-column">
                <h3>Resources</h3>
                <div class="footer-links">
                    <a href="#shorten">Create a link</a>
                    <a href="/login?mode=admin">Admin</a>
                    <a href="#about">About</a>
                </div>
            </div>

            <div class="footer-column">
                <h3>Account</h3>
                <div class="footer-links">
                    <a href="<%= user ? "#dashboard" : "/login" %>"><%= user ? "My links" : "Dashboard" %></a>
                    <a href="#shorten">New link</a>
                    <a href="#pricing">Plans</a>
                </div>
            </div>
        </div>

        <div class="container footer-bottom">
            <span>© <%= new Date().getFullYear() %> Linkly. Built for better sharing.</span>
            <span>Fast links. Clear insights. Less clutter.</span>
        </div>
    </footer>

    <script>
        function toggleMenu(button) {
            const links = document.getElementById("navLinks");
            const isOpen = links.classList.toggle("open");
            button.setAttribute("aria-expanded", String(isOpen));
        }

        async function copyLink(button) {
            const link = button.dataset.copy;

            try {
                await navigator.clipboard.writeText(link);
                button.textContent = "Copied!";
                window.setTimeout(() => {
                    button.textContent = "Copy";
                }, 1800);
            } catch (error) {
                window.prompt("Copy your short link:", link);
            }
        }

        async function deleteURL(shortId, button) {
            if (!window.confirm("Delete this short link? This cannot be undone.")) {
                return;
            }

            button.disabled = true;
            button.textContent = "Deleting...";

            try {
                const response = await fetch(`/url/${shortId}`, { method: "DELETE" });

                if (!response.ok) {
                    throw new Error("Delete request failed");
                }

                window.location.reload();
            } catch (error) {
                button.disabled = false;
                button.textContent = "Delete";
                window.alert("We could not delete this link. Please try again.");
            }
        }
    </script>
</body>
</html>
