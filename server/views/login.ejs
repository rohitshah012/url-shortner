<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Sign in to your Linkly account.">
    <title>Sign in — Linkly</title>
    <style>
        :root {
            --navy: #101828;
            --ink: #344054;
            --muted: #667085;
            --line: #e4e7ec;
            --brand: #6941c6;
            --brand-dark: #53389e;
            --brand-soft: #f4f3ff;
            --cyan: #12b7c4;
            --success: #067647;
            --success-soft: #ecfdf3;
            --danger: #b42318;
            --danger-soft: #fef3f2;
            --shadow: 0 28px 80px rgba(16, 24, 40, 0.16);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--navy);
            background: #f8f9fc;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        button, input { font: inherit; }

        .page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(440px, 0.92fr) minmax(520px, 1.08fr);
        }

        .visual-panel {
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 42px clamp(36px, 5vw, 74px);
            color: #ffffff;
            background:
                radial-gradient(circle at 15% 12%, rgba(18, 183, 196, 0.35), transparent 27%),
                radial-gradient(circle at 88% 78%, rgba(255, 255, 255, 0.13), transparent 24%),
                linear-gradient(145deg, #292056 0%, #53389e 48%, #087f8c 120%);
        }

        .visual-panel::before,
        .visual-panel::after {
            content: "";
            position: absolute;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 50%;
        }

        .visual-panel::before {
            width: 410px;
            height: 410px;
            right: -230px;
            top: -180px;
            box-shadow: 0 0 0 55px rgba(255, 255, 255, 0.035), 0 0 0 110px rgba(255, 255, 255, 0.025);
        }

        .visual-panel::after {
            width: 250px;
            height: 250px;
            left: -170px;
            bottom: 50px;
            box-shadow: 0 0 0 42px rgba(255, 255, 255, 0.035);
        }

        .brand {
            position: relative;
            z-index: 2;
            display: inline-flex;
            align-items: center;
            gap: 11px;
            align-self: flex-start;
            color: #ffffff;
            font-size: 21px;
            font-weight: 850;
            letter-spacing: -0.04em;
            text-decoration: none;
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            display: grid;
            place-items: center;
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.13);
            backdrop-filter: blur(8px);
        }

        .brand-mark svg { width: 22px; height: 22px; }

        .visual-copy {
            position: relative;
            z-index: 2;
            max-width: 580px;
            padding: 70px 0;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 22px;
            border: 1px solid rgba(255, 255, 255, 0.22);
            border-radius: 999px;
            padding: 7px 12px;
            color: rgba(255, 255, 255, 0.86);
            background: rgba(255, 255, 255, 0.08);
            font-size: 12px;
            font-weight: 750;
        }

        .eyebrow-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #5fe7d8;
            box-shadow: 0 0 0 4px rgba(95, 231, 216, 0.13);
        }

        .visual-copy h1 {
            margin: 0;
            font-size: clamp(42px, 5vw, 68px);
            line-height: 1;
            letter-spacing: -0.06em;
        }

        .visual-copy p {
            max-width: 520px;
            margin: 24px 0 0;
            color: rgba(255, 255, 255, 0.72);
            font-size: 17px;
            line-height: 1.7;
        }

        .mini-dashboard {
            position: relative;
            z-index: 2;
            max-width: 520px;
            margin-top: 38px;
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 18px;
            padding: 18px;
            background: rgba(255, 255, 255, 0.1);
            box-shadow: 0 20px 50px rgba(10, 15, 40, 0.18);
            backdrop-filter: blur(14px);
        }

        .mini-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .mini-title {
            font-size: 12px;
            font-weight: 750;
        }

        .mini-badge {
            border-radius: 999px;
            padding: 5px 9px;
            color: #d5faf5;
            background: rgba(95, 231, 216, 0.14);
            font-size: 10px;
            font-weight: 800;
        }

        .mini-link {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 14px;
            align-items: center;
            border-radius: 11px;
            padding: 13px 14px;
            background: rgba(255, 255, 255, 0.1);
        }

        .mini-link strong {
            display: block;
            margin-bottom: 4px;
            font-size: 12px;
        }

        .mini-link span {
            color: rgba(255, 255, 255, 0.58);
            font-size: 10px;
        }

        .mini-clicks {
            min-width: 40px;
            border-radius: 8px;
            padding: 8px;
            color: #ffffff;
            background: rgba(255, 255, 255, 0.12);
            font-size: 11px;
            font-weight: 800;
            text-align: center;
        }

        .visual-footer {
            position: relative;
            z-index: 2;
            color: rgba(255, 255, 255, 0.54);
            font-size: 12px;
        }

        .form-panel {
            display: grid;
            place-items: center;
            padding: 48px 28px;
            background:
                radial-gradient(circle at 90% 4%, rgba(105, 65, 198, 0.08), transparent 24%),
                #ffffff;
        }

        .form-shell {
            width: min(440px, 100%);
        }

        .mobile-brand {
            display: none;
            margin-bottom: 38px;
            color: var(--navy);
        }

        .mobile-brand .brand-mark {
            color: #ffffff;
            border: 0;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
        }

        .welcome {
            margin-bottom: 28px;
        }

        .welcome h2 {
            margin: 0;
            font-size: 36px;
            line-height: 1.1;
            letter-spacing: -0.045em;
        }

        .welcome p {
            margin: 11px 0 0;
            color: var(--muted);
            font-size: 15px;
            line-height: 1.6;
        }

        .mode-switch {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px;
            margin-bottom: 24px;
            border-radius: 12px;
            padding: 5px;
            background: #f2f4f7;
        }

        .mode-switch a {
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 9px;
            color: var(--muted);
            font-size: 13px;
            font-weight: 750;
            text-decoration: none;
            transition: color 160ms ease, background 160ms ease, box-shadow 160ms ease;
        }

        .mode-switch a.active {
            color: var(--brand-dark);
            background: #ffffff;
            box-shadow: 0 2px 7px rgba(16, 24, 40, 0.09);
        }

        .notice {
            margin-bottom: 18px;
            border-radius: 11px;
            padding: 12px 14px;
            font-size: 13px;
            font-weight: 650;
            line-height: 1.45;
        }

        .notice-success {
            border: 1px solid #abefc6;
            color: var(--success);
            background: var(--success-soft);
        }

        .notice-error {
            border: 1px solid #fecdca;
            color: var(--danger);
            background: var(--danger-soft);
        }

        .login-form {
            display: grid;
            gap: 18px;
        }

        .field {
            display: grid;
            gap: 7px;
        }

        .field label {
            color: var(--ink);
            font-size: 13px;
            font-weight: 750;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            top: 50%;
            left: 15px;
            width: 19px;
            height: 19px;
            color: #98a2b3;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .field input {
            width: 100%;
            min-height: 52px;
            border: 1px solid #d0d5dd;
            border-radius: 11px;
            padding: 0 46px;
            color: var(--navy);
            background: #ffffff;
            outline: none;
            transition: border 160ms ease, box-shadow 160ms ease;
        }

        .field input:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 4px rgba(105, 65, 198, 0.11);
        }

        .password-toggle {
            position: absolute;
            top: 50%;
            right: 11px;
            border: 0;
            padding: 7px;
            color: var(--muted);
            background: transparent;
            font-size: 12px;
            font-weight: 750;
            cursor: pointer;
            transform: translateY(-50%);
        }

        .submit-button {
            min-height: 52px;
            border: 0;
            border-radius: 11px;
            color: #ffffff;
            background: linear-gradient(100deg, var(--brand), #7f56d9);
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 12px 24px rgba(105, 65, 198, 0.24);
            transition: transform 160ms ease, box-shadow 160ms ease;
        }

        .submit-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 28px rgba(105, 65, 198, 0.31);
        }

        .signup-link {
            margin-top: 24px;
            color: var(--muted);
            font-size: 13px;
            text-align: center;
        }

        .signup-link a {
            color: var(--brand);
            font-weight: 750;
            text-decoration: none;
        }

        .trust-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            margin-top: 28px;
            color: #98a2b3;
            font-size: 11px;
        }

        @media (max-width: 920px) {
            .page { grid-template-columns: 1fr; }
            .visual-panel { display: none; }
            .form-panel { min-height: 100vh; }
            .mobile-brand { display: inline-flex; }
        }

        @media (max-width: 480px) {
            .form-panel {
                align-items: start;
                padding: 28px 20px;
            }

            .welcome h2 { font-size: 31px; }
        }
    </style>
</head>
<body>
    <% const adminMode = locals.mode === "admin"; %>

    <main class="page">
        <aside class="visual-panel">
            <a class="brand" href="/">
                <span class="brand-mark">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                    </svg>
                </span>
                Linkly
            </a>

            <div class="visual-copy">
                <div class="eyebrow"><span class="eyebrow-dot"></span>Links that lead somewhere</div>
                <h1>Welcome back to smarter sharing.</h1>
                <p>Sign in to create clean short links, see how they perform, and keep every destination organized in one place.</p>

                <div class="mini-dashboard" aria-hidden="true">
                    <div class="mini-top">
                        <span class="mini-title">Recent performance</span>
                        <span class="mini-badge">Live analytics</span>
                    </div>
                    <div class="mini-link">
                        <div>
                            <strong>linkly.app/product-launch</strong>
                            <span>Campaign destination</span>
                        </div>
                        <span class="mini-clicks">248</span>
                    </div>
                </div>
            </div>

            <span class="visual-footer">Fast links. Clear insights. Less clutter.</span>
        </aside>

        <section class="form-panel">
            <div class="form-shell">
                <a class="brand mobile-brand" href="/">
                    <span class="brand-mark">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                        </svg>
                    </span>
                    Linkly
                </a>

                <header class="welcome">
                    <h2><%= adminMode ? "Admin access" : "Welcome back" %></h2>
                    <p><%= adminMode ? "Use your administrator credentials to open the control center." : "Enter your details to continue to your dashboard." %></p>
                </header>

                <div class="mode-switch" aria-label="Choose login type">
                    <a href="/login" class="<%= adminMode ? "" : "active" %>">User login</a>
                    <a href="/login?mode=admin" class="<%= adminMode ? "active" : "" %>">Admin login</a>
                </div>

                <% if (locals.success) { %>
                    <div class="notice notice-success"><%= success %></div>
                <% } %>

                <% if (locals.error) { %>
                    <div class="notice notice-error"><%= error %></div>
                <% } %>

                <form class="login-form" action="<%= adminMode ? "/user/admin-login" : "/user/login" %>" method="POST">
                    <div class="field">
                        <label for="email">Email address</label>
                        <div class="input-wrap">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16v16H4z"/>
                                <path d="m4 6 8 6 8-6"/>
                            </svg>
                            <input type="email" name="email" id="email" placeholder="you@example.com" autocomplete="email" value="<%= locals.email ? email : "" %>" required autofocus>
                        </div>
                    </div>

                    <div class="field">
                        <label for="password">Password</label>
                        <div class="input-wrap">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="4" y="10" width="16" height="11" rx="2"/>
                                <path d="M8 10V7a4 4 0 0 1 8 0v3"/>
                            </svg>
                            <input type="password" name="password" id="password" placeholder="Enter your password" autocomplete="current-password" required>
                            <button class="password-toggle" type="button" onclick="togglePassword(this)">Show</button>
                        </div>
                    </div>

                    <button class="submit-button" type="submit"><%= adminMode ? "Open admin dashboard" : "Sign in to Linkly" %></button>
                </form>

                <% if (!adminMode) { %>
                    <p class="signup-link">New to Linkly? <a href="/signup">Create a free account</a></p>
                <% } %>

                <div class="trust-row"><span aria-hidden="true">🔒</span> Secure, encrypted account access</div>
            </div>
        </section>
    </main>

    <script>
        function togglePassword(button) {
            const input = document.getElementById("password");
            const showing = input.type === "text";
            input.type = showing ? "password" : "text";
            button.textContent = showing ? "Show" : "Hide";
        }
    </script>
</body>
</html>
