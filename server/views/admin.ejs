<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Linkly administration dashboard.">
    <title>Admin dashboard — Linkly</title>
    <style>
        :root {
            --navy: #101828;
            --navy-soft: #1d2939;
            --ink: #344054;
            --muted: #667085;
            --line: #e4e7ec;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --brand: #6941c6;
            --brand-dark: #53389e;
            --brand-soft: #f4f3ff;
            --cyan: #12b7c4;
            --cyan-soft: #ecfdff;
            --success: #067647;
            --success-soft: #ecfdf3;
            --warning: #b54708;
            --warning-soft: #fffaeb;
            --danger: #b42318;
            --shadow: 0 10px 30px rgba(16, 24, 40, 0.07);
        }

        * { box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            color: var(--navy);
            background: var(--surface-soft);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        button, input { font: inherit; }
        a { color: inherit; }

        .sidebar {
            position: fixed;
            inset: 0 auto 0 0;
            z-index: 40;
            width: 248px;
            display: flex;
            flex-direction: column;
            padding: 26px 18px 22px;
            color: #d0d5dd;
            background:
                radial-gradient(circle at 10% 4%, rgba(105, 65, 198, 0.35), transparent 26%),
                var(--navy);
        }

        .brand {
            display: inline-flex;
            align-items: center;
            gap: 11px;
            margin: 0 10px 34px;
            color: #ffffff;
            font-size: 20px;
            font-weight: 850;
            letter-spacing: -0.04em;
            text-decoration: none;
        }

        .brand-mark {
            width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            color: #ffffff;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
            box-shadow: 0 10px 24px rgba(105, 65, 198, 0.3);
        }

        .brand-mark svg { width: 21px; height: 21px; }

        .nav-label {
            margin: 0 12px 10px;
            color: #667085;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .side-nav {
            display: grid;
            gap: 5px;
        }

        .side-link {
            min-height: 44px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-radius: 10px;
            padding: 0 13px;
            color: #98a2b3;
            font-size: 13px;
            font-weight: 650;
            text-decoration: none;
            transition: color 160ms ease, background 160ms ease;
        }

        .side-link:hover,
        .side-link.active {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.09);
        }

        .side-link.active {
            box-shadow: inset 3px 0 var(--cyan);
        }

        .side-link svg {
            width: 19px;
            height: 19px;
        }

        .sidebar-bottom {
            margin-top: auto;
            border-top: 1px solid #344054;
            padding-top: 18px;
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: 11px;
            margin-bottom: 14px;
            padding: 0 8px;
        }

        .avatar {
            width: 36px;
            height: 36px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            border-radius: 10px;
            color: #ffffff;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
            font-size: 13px;
            font-weight: 850;
        }

        .admin-profile div {
            min-width: 0;
        }

        .admin-profile strong,
        .admin-profile span {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .admin-profile strong {
            color: #ffffff;
            font-size: 12px;
        }

        .admin-profile span {
            margin-top: 3px;
            color: #667085;
            font-size: 10px;
        }

        .logout-button {
            width: 100%;
            min-height: 40px;
            border: 1px solid #344054;
            border-radius: 9px;
            color: #d0d5dd;
            background: transparent;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .logout-button:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.06);
        }

        .main {
            min-height: 100vh;
            margin-left: 248px;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 30;
            min-height: 74px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            border-bottom: 1px solid rgba(228, 231, 236, 0.9);
            padding: 0 34px;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
        }

        .topbar-title {
            display: flex;
            align-items: center;
            gap: 11px;
        }

        .mobile-menu {
            display: none;
            width: 40px;
            height: 40px;
            border: 1px solid var(--line);
            border-radius: 10px;
            background: #ffffff;
            cursor: pointer;
        }

        .topbar-title strong {
            font-size: 15px;
            letter-spacing: -0.02em;
        }

        .admin-badge {
            border-radius: 999px;
            padding: 5px 9px;
            color: var(--brand-dark);
            background: var(--brand-soft);
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .search-wrap {
            position: relative;
        }

        .search-wrap svg {
            position: absolute;
            top: 50%;
            left: 13px;
            width: 17px;
            height: 17px;
            color: #98a2b3;
            transform: translateY(-50%);
        }

        .search-input {
            width: 260px;
            min-height: 40px;
            border: 1px solid #d0d5dd;
            border-radius: 10px;
            padding: 0 13px 0 39px;
            color: var(--navy);
            background: #ffffff;
            outline: none;
        }

        .search-input:focus {
            border-color: var(--brand);
            box-shadow: 0 0 0 4px rgba(105, 65, 198, 0.1);
        }

        .view-site {
            min-height: 40px;
            display: inline-flex;
            align-items: center;
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 0 13px;
            color: var(--ink);
            background: #ffffff;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
        }

        .content {
            width: min(1240px, calc(100% - 58px));
            margin: 0 auto;
            padding: 38px 0 64px;
        }

        .page-head {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 24px;
            margin-bottom: 28px;
        }

        .page-head h1 {
            margin: 0;
            font-size: 34px;
            line-height: 1.1;
            letter-spacing: -0.05em;
        }

        .page-head p {
            margin: 9px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .date-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            border: 1px solid var(--line);
            border-radius: 9px;
            padding: 9px 12px;
            color: var(--muted);
            background: #ffffff;
            font-size: 11px;
            font-weight: 650;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
            margin-bottom: 28px;
        }

        .stat-card {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--line);
            border-radius: 16px;
            padding: 22px;
            background: #ffffff;
            box-shadow: 0 4px 14px rgba(16, 24, 40, 0.04);
        }

        .stat-card::after {
            content: "";
            position: absolute;
            top: -28px;
            right: -28px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: var(--tint, var(--brand-soft));
        }

        .stat-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .stat-icon {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 11px;
            color: var(--accent, var(--brand));
            background: var(--tint, var(--brand-soft));
        }

        .stat-icon svg { width: 20px; height: 20px; }

        .stat-trend {
            position: relative;
            z-index: 1;
            color: var(--success);
            font-size: 10px;
            font-weight: 750;
        }

        .stat-card strong {
            display: block;
            margin-bottom: 5px;
            font-size: 30px;
            letter-spacing: -0.045em;
        }

        .stat-card span {
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
        }

        .section-card {
            border: 1px solid var(--line);
            border-radius: 18px;
            background: #ffffff;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            border-bottom: 1px solid var(--line);
            padding: 22px 24px;
        }

        .section-head h2 {
            margin: 0 0 5px;
            font-size: 19px;
            letter-spacing: -0.03em;
        }

        .section-head p {
            margin: 0;
            color: var(--muted);
            font-size: 12px;
        }

        .result-count {
            border-radius: 999px;
            padding: 6px 10px;
            color: var(--brand-dark);
            background: var(--brand-soft);
            font-size: 10px;
            font-weight: 800;
        }

        .users-list {
            display: grid;
        }

        .user-card {
            border-bottom: 1px solid var(--line);
        }

        .user-card:last-child {
            border-bottom: 0;
        }

        .user-summary {
            display: grid;
            grid-template-columns: minmax(230px, 1.4fr) repeat(2, minmax(90px, 0.45fr)) auto;
            gap: 20px;
            align-items: center;
            padding: 20px 24px;
            cursor: pointer;
            transition: background 160ms ease;
        }

        .user-summary:hover {
            background: #fcfcfd;
        }

        .user-identity {
            display: flex;
            align-items: center;
            gap: 13px;
            min-width: 0;
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            border-radius: 12px;
            color: var(--brand-dark);
            background: var(--brand-soft);
            font-size: 14px;
            font-weight: 850;
        }

        .user-identity strong,
        .user-identity span {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-identity strong {
            margin-bottom: 4px;
            font-size: 13px;
        }

        .user-identity span {
            color: var(--muted);
            font-size: 11px;
        }

        .user-metric strong {
            display: block;
            margin-bottom: 3px;
            font-size: 15px;
        }

        .user-metric span {
            color: var(--muted);
            font-size: 10px;
        }

        .toggle-button {
            width: 34px;
            height: 34px;
            display: grid;
            place-items: center;
            border: 1px solid var(--line);
            border-radius: 9px;
            color: var(--muted);
            background: #ffffff;
            cursor: pointer;
            transition: transform 180ms ease;
        }

        .user-card.open .toggle-button {
            transform: rotate(180deg);
        }

        .user-details {
            display: none;
            border-top: 1px solid var(--line);
            background: #fcfcfd;
        }

        .user-card.open .user-details {
            display: block;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 760px;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 14px 24px;
            border-bottom: 1px solid var(--line);
            text-align: left;
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: 0; }

        th {
            color: var(--muted);
            background: #f9fafb;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.07em;
            text-transform: uppercase;
        }

        td {
            color: var(--ink);
            font-size: 11px;
        }

        .short-link {
            color: var(--brand);
            font-weight: 750;
            text-decoration: none;
        }

        .short-link:hover { text-decoration: underline; }

        .destination {
            max-width: 330px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .visit-badge {
            display: inline-flex;
            border-radius: 999px;
            padding: 5px 9px;
            color: #026aa2;
            background: #f0f9ff;
            font-weight: 750;
        }

        .copy-button {
            border: 1px solid var(--line);
            border-radius: 7px;
            padding: 6px 9px;
            color: var(--muted);
            background: #ffffff;
            font-size: 10px;
            font-weight: 700;
            cursor: pointer;
        }

        .user-empty,
        .global-empty {
            padding: 34px 24px;
            color: var(--muted);
            font-size: 12px;
            text-align: center;
        }

        .global-empty {
            padding: 70px 24px;
        }

        .global-empty-icon {
            width: 52px;
            height: 52px;
            display: grid;
            place-items: center;
            margin: 0 auto 14px;
            border-radius: 14px;
            color: var(--brand);
            background: var(--brand-soft);
            font-size: 20px;
        }

        .global-empty h3 {
            margin: 0 0 6px;
            color: var(--navy);
            font-size: 16px;
        }

        .hidden {
            display: none !important;
        }

        @media (max-width: 1000px) {
            .sidebar {
                width: 220px;
                transform: translateX(-100%);
                transition: transform 200ms ease;
            }

            .sidebar.open { transform: translateX(0); }
            .main { margin-left: 0; }
            .mobile-menu { display: grid; place-items: center; }
            .stats-grid { grid-template-columns: repeat(3, 1fr); }
        }

        @media (max-width: 760px) {
            .topbar { padding: 0 18px; }
            .search-wrap { display: none; }
            .content { width: min(100% - 28px, 1240px); padding-top: 28px; }
            .page-head { align-items: flex-start; flex-direction: column; }
            .stats-grid { grid-template-columns: 1fr; }
            .user-summary {
                grid-template-columns: 1fr auto;
            }
            .user-summary .user-metric { display: none; }
        }

        @media (max-width: 480px) {
            .view-site { display: none; }
            .page-head h1 { font-size: 29px; }
            .section-head { align-items: flex-start; flex-direction: column; }
        }
    </style>
</head>
<body>
    <%
        const totalUsers = users ? users.length : 0;
        const totalUrls = users ? users.reduce((sum, account) => sum + account.totalUrls, 0) : 0;
        const totalVisits = users ? users.reduce((sum, account) => sum + account.totalVisits, 0) : 0;
        const adminInitial = user.email ? user.email.charAt(0).toUpperCase() : "A";
    %>

    <aside class="sidebar" id="sidebar">
        <a class="brand" href="/admin/urls">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
            </span>
            Linkly
        </a>

        <p class="nav-label">Workspace</p>
        <nav class="side-nav">
            <a class="side-link active" href="/admin/urls">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Overview
            </a>
            <a class="side-link" href="#users">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Users
            </a>
            <a class="side-link" href="#users">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                Links
            </a>
        </nav>

        <div class="sidebar-bottom">
            <div class="admin-profile">
                <span class="avatar"><%= adminInitial %></span>
                <div>
                    <strong>Administrator</strong>
                    <span title="<%= user.email %>"><%= user.email %></span>
                </div>
            </div>
            <form action="/user/logout" method="POST">
                <button class="logout-button" type="submit">Sign out</button>
            </form>
        </div>
    </aside>

    <div class="main">
        <header class="topbar">
            <div class="topbar-title">
                <button class="mobile-menu" type="button" aria-label="Toggle sidebar" onclick="toggleSidebar()">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
                </button>
                <strong>Control center</strong>
                <span class="admin-badge">Admin</span>
            </div>

            <div class="topbar-actions">
                <div class="search-wrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
                    <input class="search-input" type="search" id="userSearch" placeholder="Search users or email..." oninput="filterUsers(this.value)">
                </div>
                <a class="view-site" href="/login">View site ↗</a>
            </div>
        </header>

        <main class="content">
            <header class="page-head">
                <div>
                    <h1>Dashboard overview</h1>
                    <p>Monitor users, short links, and total engagement across Linkly.</p>
                </div>
                <span class="date-chip">Updated <%= new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></span>
            </header>

            <section class="stats-grid" aria-label="Platform statistics">
                <article class="stat-card" style="--accent: var(--brand); --tint: var(--brand-soft);">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/></svg>
                        </span>
                        <span class="stat-trend">Active accounts</span>
                    </div>
                    <strong><%= totalUsers %></strong>
                    <span>Registered users</span>
                </article>

                <article class="stat-card" style="--accent: #087f8c; --tint: var(--cyan-soft);">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                        </span>
                        <span class="stat-trend">All time</span>
                    </div>
                    <strong><%= totalUrls %></strong>
                    <span>Short links created</span>
                </article>

                <article class="stat-card" style="--accent: var(--warning); --tint: var(--warning-soft);">
                    <div class="stat-top">
                        <span class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m7 16 4-5 4 3 5-7"/></svg>
                        </span>
                        <span class="stat-trend">Total traffic</span>
                    </div>
                    <strong><%= totalVisits %></strong>
                    <span>Recorded link visits</span>
                </article>
            </section>

            <section class="section-card" id="users">
                <div class="section-head">
                    <div>
                        <h2>User activity</h2>
                        <p>Expand an account to inspect its links and engagement.</p>
                    </div>
                    <span class="result-count" id="resultCount"><%= totalUsers %> users</span>
                </div>

                <% if (users && users.length > 0) { %>
                    <div class="users-list" id="usersList">
                        <% users.forEach((account, index) => { %>
                            <article class="user-card <%= index === 0 ? "open" : "" %>" data-search="<%= `${account.name} ${account.email}`.toLowerCase() %>">
                                <div class="user-summary" onclick="toggleUser(this)">
                                    <div class="user-identity">
                                        <span class="user-avatar"><%= account.name ? account.name.charAt(0).toUpperCase() : "U" %></span>
                                        <div>
                                            <strong><%= account.name %></strong>
                                            <span><%= account.email %></span>
                                        </div>
                                    </div>
                                    <div class="user-metric">
                                        <strong><%= account.totalUrls %></strong>
                                        <span>Short links</span>
                                    </div>
                                    <div class="user-metric">
                                        <strong><%= account.totalVisits %></strong>
                                        <span>Total visits</span>
                                    </div>
                                    <button class="toggle-button" type="button" aria-label="Toggle user details">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                                    </button>
                                </div>

                                <div class="user-details">
                                    <% if (account.urls && account.urls.length > 0) { %>
                                        <div class="table-wrap">
                                            <table>
                                                <thead>
                                                    <tr>
                                                        <th>Short link</th>
                                                        <th>Destination</th>
                                                        <th>Visits</th>
                                                        <th>Created</th>
                                                        <th>Copy</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% account.urls.forEach(url => { %>
                                                        <% const fullShortUrl = `${baseUrl}/url/${url.Shortid}`; %>
                                                        <tr>
                                                            <td><a class="short-link" href="<%= fullShortUrl %>" target="_blank" rel="noopener noreferrer">/url/<%= url.Shortid %></a></td>
                                                            <td class="destination" title="<%= url.RedirectUrl %>"><%= url.RedirectUrl %></td>
                                                            <td><span class="visit-badge"><%= url.VisitHistory.length %></span></td>
                                                            <td><%= new Date(url.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %></td>
                                                            <td><button class="copy-button" type="button" data-copy="<%= fullShortUrl %>" onclick="copyLink(this)">Copy</button></td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        </div>
                                    <% } else { %>
                                        <div class="user-empty">This user has not created any short links yet.</div>
                                    <% } %>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="global-empty">
                        <div class="global-empty-icon">◎</div>
                        <h3>No users yet</h3>
                        <p>New user accounts will appear here after signup.</p>
                    </div>
                <% } %>
            </section>
        </main>
    </div>

    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("open");
        }

        function toggleUser(summary) {
            summary.closest(".user-card").classList.toggle("open");
        }

        function filterUsers(value) {
            const query = value.trim().toLowerCase();
            const cards = document.querySelectorAll(".user-card");
            let visible = 0;

            cards.forEach((card) => {
                const matches = card.dataset.search.includes(query);
                card.classList.toggle("hidden", !matches);
                if (matches) visible += 1;
            });

            document.getElementById("resultCount").textContent = `${visible} ${visible === 1 ? "user" : "users"}`;
        }

        async function copyLink(button) {
            try {
                await navigator.clipboard.writeText(button.dataset.copy);
                button.textContent = "Copied";
                window.setTimeout(() => {
                    button.textContent = "Copy";
                }, 1600);
            } catch (error) {
                window.prompt("Copy this link:", button.dataset.copy);
            }
        }
    </script>
</body>
</html>
