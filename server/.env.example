# MongoDB Connection URI
MONGO_URI=mongodb://localhost:27017/urlshortner

# JWT Secret Key (use a strong random string)
JWT_SECRET=your_jwt_secret_key_here_change_this_to_something_secure

# Server Port (optional, defaults to 5000)
PORT=5000

# Use "production" only when serving the app over HTTPS
NODE_ENV=development

# Required only when running: npm run create-admin
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
